power_sim(
within  = list(time = c("pre","post")),
between = list(group = c("control","treat")),
n   = 40,
mu  = c(10,10,10,13),
sd  = 2,
r   = 0.6,
nsim = 1000,
test = function(d){
t.test(d$post[d$group=="treat"],
d$post[d$group=="control"])$p.value
}
)

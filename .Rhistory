df <- rmulti(
n = 200,
dist = list(
score  = list(dist="norm", mu=50, sd=10),
count  = list(dist="pois", lambda=4),
rating = list(dist="likert", items=5),
prop   = list(dist="beta", shape1=2, shape2=5)
),
r = 0.4
)
head(df)

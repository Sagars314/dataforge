df <- forge_design(
within = list(time=c("pre","post")),
between = list(method=c("traditional","interactive")),
n=50,
mu=c(60,65,60,75),
sd=10,
r=.5,
plot=FALSE
)
# convert to long
df_long <- wide2long(df, within="time")
# add missing values
df_long <- messy(df_long, prop=.05)
# check statistics
check_sim_stats(df_long)
forge_df(
df,
n = NULL,
between = NULL,
dv = NULL,
id = "id",
empirical = FALSE,
seed = NULL
)

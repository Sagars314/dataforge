sim_results <- replicate(500, {
df <- forge_design(
within  = list(time=c("pre","post")),
between = list(group=c("control","treatment")),
n = 30,
mu = c(50,50, 50,55),
sd = 10,
r = 0.5,
long = TRUE,
plot = FALSE
)
p <- summary(aov(y ~ group*time + Error(id/time), df))[[2]][[1]]["group:time","Pr(>F)"]
p < .05
})
mean(sim_results)

design <-
add_random(subject = 120, item = 40) |>
# repeated measurement
add_within(time = c("immediate","delayed")) |>
# between-subject manipulation
add_between(strategy = c("massed","spaced"), .by = "subject") |>
# item property
add_between(difficulty = c("easy","hard"), .by = "item")
plot_design(design)
dim(design)
|> head(design)
design <- design |>
add_ranef(subject = 8) |>   # ability differences
add_ranef(item = 6)         # item difficulty variation
design$mu <-
70 +
# main effects
ifelse(design$strategy == "spaced", 6, 0) +
ifelse(design$time == "delayed", -8, 0) +
ifelse(design$difficulty == "hard", -10, 0) +
# interaction effects
ifelse(design$strategy == "spaced" &
design$time == "delayed", 6, 0) +
ifelse(design$strategy == "spaced" &
design$difficulty == "hard", 4, 0) +
# random effects
design$subject_ranef +
design$item_ranef
set.seed(123)
design$score <- rnorm(
nrow(design),
mean = design$mu,
sd = 5
)
head(design)
View(design)
design <- design |>
add_recode("strategy",
massed = 0,
spaced = 1,
.new_col = "strategy_num")
forge_plot(design, score ~ strategy_num) +
geom_point() +
geom_smooth(method = "lm")
forge_plot(design)
forge_codebook(design)
?forge_codebook
forge_codebook(design, output = "print")

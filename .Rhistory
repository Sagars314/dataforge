.dataforge_env <- new.env(parent = emptyenv())
.onLoad <- function(libname, pkgname) {
if (!exists(".dataforge_env", envir = parent.env(environment()))) {
assign(".dataforge_env", new.env(parent = emptyenv()),
envir = parent.env(environment()))
}
.dataforge_env$verbose <- TRUE
.dataforge_env$plot <- TRUE
}

chat$chat("Create a function for printing natural numbers up to a given limit in R")
#' @examples
#' print_natural_numbers_cat(5)
#' print_natural_numbers_cat(1)
#' print_natural_numbers_cat(0) # Handles edge case
#' print_natural_numbers_cat(-3) # Handles edge case
print_natural_numbers_cat <- function(limit) {
# Input validation
if (!is.numeric(limit) || length(limit) != 1) {
stop("Limit must be a single numeric value.")
}
# Ensure limit is treated as an integer for natural numbers
limit <- floor(limit)
if (limit < 1) {
message("The limit for natural numbers must be at least 1. No numbers will be
printed.")
return(invisible(NULL)) # Return invisible NULL for functions with side effects
}
# Generate the sequence of natural numbers from 1 up to the limit
numbers <- 1:limit
# Use cat to print them, separated by spaces, followed by a newline
cat(numbers, "\n")
return(invisible(NULL)) # Good practice for functions that print
}
print_natural_numbers_cat(5)

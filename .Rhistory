df <- forge_design(
within  = list(time = c("pre","post")),
between = list(method = c("traditional","interactive")),
n  = 40,
# expected mean scores
mu = c(
60, 65,   # traditional group improves slightly
60, 75    # interactive group improves more
),
sd = 8,     # variability in scores
r  = 0.6    # correlation between pre and post scores
)
df
